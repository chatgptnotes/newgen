# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HeyGen
HEYGEN_API_KEY=your-heygen-api-key
HEYGEN_AVATAR_ID=your-avatar-id
HEYGEN_VOICE_ID=your-voice-id

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your-ig-access-token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-ig-business-account-id

# YouTube Data API v3
YOUTUBE_CLIENT_ID=your-google-client-id
YOUTUBE_CLIENT_SECRET=your-google-client-secret
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token

# Cron Secret (for securing the /api/cron endpoint)
CRON_SECRET=your-cron-secret
